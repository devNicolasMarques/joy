    },
    {
      "id": "UO9mKOzGpeFuPgGxSsHBH",
      "type": "text",
      "x": 1114.6999206062976,
      "y": 556.7975753249887,
      "width": 284.63983154296875,
      "height": 25,
      "angle": 0,
      "strokeColor": "#c2255c",
      "backgroundColor": "#ffc9c9",
