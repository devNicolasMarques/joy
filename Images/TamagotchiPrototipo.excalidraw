      "isDeleted": false,
      "boundElements": null,
      "updated": 1780161561468,
      "link": null,
      "locked": false,
      "text": "O que é Tamagotchi?",
      "fontSize": 20,
      "fontFamily": 5,
      "textAlign": "center",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "O que é Tamagotchi?",
      "autoResize": true,
      "lineHeight": 1.25
    },
    {
      "id": "1ljq_TqdUkyMwfnwRoo_k",
      "type": "text",
      "x": 1114.6999209675164,
      "y": 276.0287913825402,
      "width": 298.7829825426541,
      "height": 114.94241748314647,
      "angle": 0,
      "strokeColor": "#1e1e1e",
      "backgroundColor": "transparent",
      "fillStyle": "solid",
      "strokeWidth": 2,
      "strokeStyle": "solid",
      "roughness": 1,
      "opacity": 100,
      "groupIds": [],
      "frameId": null,
      "index": "ah",
      "roundness": null,
      "seed": 246952090,
      "version": 615,
      "versionNonce": 256961926,
      "isDeleted": false,
      "boundElements": [],
      "updated": 1780161569086,
      "link": null,
      "locked": false,
      "text": "Um Tamagotchi (frequentemente chamado de\n\"bichinho virtual\") é um clássico brinquedo eletrônico\nportátil lançado originalmente no Japão em 1996. Ele\nsimula a criação de um animal de estimação digital,\nonde o dono precisa alimentá-lo, limpá-lo, dar remédio\nquando adoecer e brincar com ele.O nome é uma\njunção de \"tamago\" (que significa \"ovo\" em japonês) e\n\"watch\" (relógio)",
      "fontSize": 11.494241748314646,
      "fontFamily": 5,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "Um Tamagotchi (frequentemente chamado de \"bichinho virtual\") é um clássico brinquedo eletrônico portátil lançado originalmente no Japão em 1996. Ele simula a criação de um animal de estimação digital, onde o dono precisa alimentá-lo, limpá-lo, dar remédio quando adoecer e brincar com ele.O nome é uma junção de \"tamago\" (que significa \"ovo\" em japonês) e \"watch\" (relógio)",
      "autoResize": false,
      "lineHeight": 1.25
    },
    {
      "id": "kJz6FqFwSnQNUwnhGHOPv",
      "type": "rectangle",
      "x": 1420.7242259252093,
      "y": 267.84561032422243,
      "width": 113.46787461969237,
      "height": 112.62109943596306,
      "angle": 0,
      "strokeColor": "#c2255c",
      "backgroundColor": "#ffc9c9",
      "fillStyle": "solid",
      "strokeWidth": 1,
      "strokeStyle": "solid",
      "roughness": 1,
      "opacity": 100,
      "groupIds": [],
