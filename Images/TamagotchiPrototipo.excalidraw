    {
      "id": "1vEG5AIkXMEMdENlH2cZ6",
      "type": "text",
      "x": 1114.6999206957082,
      "y": 245.31320212624752,
      "width": 204.0598907470703,
      "height": 25,
      "angle": 0,
      "strokeColor": "#c2255c",
      "backgroundColor": "#ffc9c9",
      "fillStyle": "solid",
      "strokeWidth": 1,
      "strokeStyle": "solid",
      "roughness": 1,
      "opacity": 100,
      "groupIds": [],
