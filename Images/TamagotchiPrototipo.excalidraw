      "isDeleted": false,
      "boundElements": [],
      "updated": 1780162106052,
      "link": null,
      "locked": false,
      "text": "Por que escolhi o Tamagochi?",
      "fontSize": 20,
      "fontFamily": 5,
      "textAlign": "right",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "Por que escolhi o Tamagochi?",
      "autoResize": true,
      "lineHeight": 1.25
    },
    {
      "id": "Xi5M8KK9jG6O-KRgfBXpR",
      "type": "text",
      "x": 1235.4091184674303,
      "y": 446.8586582105109,
      "width": 298.7829825426541,
      "height": 86.20681311235985,
      "angle": 0,
      "strokeColor": "#1e1e1e",
      "backgroundColor": "transparent",
      "fillStyle": "solid",
      "strokeWidth": 2,
      "strokeStyle": "solid",
      "roughness": 1,
      "opacity": 100,
      "groupIds": [],
      "frameId": null,
      "index": "ak",
      "roundness": null,
      "seed": 164445830,
      "version": 1399,
      "versionNonce": 2082954310,
      "isDeleted": false,
      "boundElements": [],
      "updated": 1780162100464,
      "link": null,
      "locked": false,
      "text": "Meu nome é Joyce, trabalho na área de\ndesenvolvimento de sistemas a 1 ano e meio, mas sou\nmais focada no desenvolvimento front-end,\nespecificamente com HTML/CSS puro e React. Sou\napaixonada por cultura asiática, gastronomia, jogos\nindie e artes manuais.",
      "fontSize": 11.494241748314646,
      "fontFamily": 5,
      "textAlign": "right",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "Meu nome é Joyce, trabalho na área de desenvolvimento de sistemas a 1 ano e meio, mas sou mais focada no desenvolvimento front-end, especificamente com HTML/CSS puro e React. Sou apaixonada por cultura asiática, gastronomia, jogos indie e artes manuais.",
      "autoResize": false,
      "lineHeight": 1.25
    },
    {
      "id": "iuKUEv3Na-iVTjFX4Vs6p",
      "type": "text",
      "x": 1403.032188781175,
      "y": 411.7074239676572,
      "width": 131.159912109375,
      "height": 25,
      "angle": 0,
      "strokeColor": "#c2255c",
      "backgroundColor": "#ffc9c9",
      "fillStyle": "solid",
      "strokeWidth": 1,
      "strokeStyle": "solid",
      "roughness": 1,
      "opacity": 100,
      "groupIds": [],
      "frameId": null,
      "index": "am",
